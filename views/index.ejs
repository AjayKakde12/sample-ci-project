<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SSR Counter App</title>
    <meta name="description" content="A beautiful counter application built with Express, EJS, and TypeScript">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="container">
        <div class="card">
            <h1>Global Counter</h1>
            <p class="subtitle">Hi There, I'm Ajay</p>

            <div class="counter-display">
                <span id="counter-value">
                    <%= counter %>
                </span>
            </div>

            <div class="controls">
                <button id="decrement-btn" class="btn btn-secondary">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Decrement
                </button>
                <button id="increment-btn" class="btn btn-primary">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Increment
                </button>
            </div>
        </div>
    </div>
    <script src="/script.js"></script>
</body>

</html>